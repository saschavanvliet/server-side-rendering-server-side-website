<%- include('./partials/head') %>
<body>
  <header>
    <nav id="navbar">
      <div class="navlogo">
      <a href="https://redpers.nl/"><img src="assets/RedPers_Logo_Cmyk_Black.webp" alt="Logo Redpers" width="400px" height="96px">
      </a>
      </div>
      <ul>
        <li><a href="https://redpers.nl/binnekort/">Alumni</a></li>
        <li><a href="https://redpers.nl/colofon/">Colofon</a></li>
        <li><a href="https://redpers.nl/over-red-pers/">Over</a></li>
        <li><a href="https://redpers.nl/meedoen/">Meedoen</a></li>
        <li><a href="https://redpers.nl/contact/">Contact</a></li>
    </ul>
    </nav>
  </header>
  <main>
    <ul class="home-articles">
      <% articles.forEach(article => {
            { %>
            <article>
              <section>
              <a href="/artikel/<%=article.id%>">
              <a href="/artikel/<%=article.slug%>">
                <img src="<%=article.jetpack_featured_media_url%>">
                <h2><%-article.title.rendered%></h2>
                  <h3><%=article.yoast_head_json.author%>&nbsp;<span class="leestijd-articles"> - 3 min</span></h3>
              </a>
              </section>
              %>
            </article>
          <% }
        }) %>
  </ul>
  </main>
</body>
  <%- include('./partials/foot') %>